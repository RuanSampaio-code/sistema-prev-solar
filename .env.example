# PostgreSQL
POSTGRES_USER=prevsolar
POSTGRES_PASSWORD=prevsolar_secret
POSTGRES_DB=prevsolar_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Backend
BACKEND_CORS_ORIGINS=http://localhost:3000
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=200

# IA - parâmetros de estimativa energética
# Fórmula: kWh/mês = área_m² × IRRADIACAO_LOCAL × EFICIENCIA_MEDIA × (1 - PERDAS_SISTEMA) × 30
IRRADIACAO_LOCAL=5.5   # kWh/m²/dia — São Luís-MA (média anual INMET)
EFICIENCIA_MEDIA=0.18  # eficiência típica de painel fotovoltaico (18%)
PERDAS_SISTEMA=0.14    # perdas por cabeamento, inversor, sujeira etc.
